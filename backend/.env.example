# Copy to .env and adjust. Never commit real secrets.

SECRET_KEY=change-me
DEBUG=True

# Comma-separated hosts, e.g. localhost,127.0.0.1
ALLOWED_HOSTS=localhost,127.0.0.1

# Database
DB_NAME=book_my_event
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432

# URLs
SITE_URL=http://localhost:8000
# Frontend origin (used in CORS defaults and verification/reset email links)
FRONTEND_URL=http://localhost:3000
# Optional: override CORS allowlist (comma-separated). When DEBUG=True, localhost ports are also allowed via regex.

# Email (required when DEBUG=False for verification / password reset)
# For local dev with DEBUG=True, users are auto-verified and email is optional.
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=no-reply@bookmyevent.com

REDIS_URL=
